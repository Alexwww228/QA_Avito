[flake8]
# Flake8 configuration for Avito API Tests

# Maximum line length
max-line-length = 100

# Ignore specific errors
ignore =
    E203,  # whitespace before ':'
    E266,  # too many leading '#' for block comment
    E501,  # line too long (handled by black)
    W503,  # line break before binary operator
    W504   # line break after binary operator

# Exclude directories
exclude =
    .git,
    __pycache__,
    .pytest_cache,
    .venv,
    venv,
    env,
    build,
    dist,
    *.egg-info,
    allure-results,
    allure-report

# Maximum complexity
max-complexity = 10

# Show source code for errors
show-source = True

# Show statistics
statistics = True

# Count errors
count = True
